                        "topic":  "Name the Emotion",
                        "duration_minutes":  2,
                        "goal":  "Increase emotional awareness",
                        "micro_action":  "Pause and name one feeling in one word right now.",
                        "reflection_prompt":  "What triggered this feeling?"
                    },
                    {
