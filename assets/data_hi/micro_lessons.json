                        "topic":  "Thought vs Fact",
                        "duration_minutes":  3,
                        "goal":  "Reduce cognitive distortion",
                        "micro_action":  "Write one stressful thought, then write one objective fact.",
                        "reflection_prompt":  "Is this thought 100% true?"
                    },
                    {
