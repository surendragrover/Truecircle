                        "topic":  "Body Reset Breath",
                        "duration_minutes":  2,
                        "goal":  "Lower stress arousal",
                        "micro_action":  "Take 5 rounds of slow inhale (4s) and exhale (6s).",
                        "reflection_prompt":  "How did your body feel before vs after?"
                    },
                    {
